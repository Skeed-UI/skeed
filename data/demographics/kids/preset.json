      "family": "Fredoka",
      "fallback": ["Nunito", "system-ui", "sans-serif"],
      "weights": [400, 500, 600, 700],
      "features": ["ss01"]
    },
    "body": {
      "family": "Nunito",
      "fallback": ["system-ui", "sans-serif"],
      "weights": [400, 600, 700, 800],
      "features": []
    },
    "mono": {
      "family": "JetBrains Mono",
      "fallback": ["ui-monospace", "monospace"],
      "weights": [400, 600],
      "features": []
    },
    "numeric": {
      "family": "Lexend",
      "fallback": ["Nunito", "system-ui", "sans-serif"],
      "weights": [500, 700],
      "features": ["tnum"]
    },
    "scale": [0.75, 0.875, 1.0, 1.125, 1.25, 1.5, 1.875, 2.25, 3.0, 3.75, 4.5]
  },
  "spacing": [0, 4, 8, 12, 16, 24, 32, 48, 64, 96, 128],
  "radius": [0, 8, 12, 16, 24, 32, 48, 9999],
  "density": {
    "compact": { "padY": 8, "padX": 12, "gap": 8, "lineHeight": 1.4 },
    "cozy": { "padY": 12, "padX": 16, "gap": 12, "lineHeight": 1.5 },
    "comfy": { "padY": 16, "padX": 24, "gap": 16, "lineHeight": 1.6 }
  },
  "motion": {
    "profile": "playful",
    "durations": {
      "fast": 200,
      "normal": 320,
      "slow": 480,
      "bounce": 600
    },
    "easings": {
      "default": "cubic-bezier(0.4, 0, 0.2, 1)",
      "bounce": "cubic-bezier(0.5, 1.6, 0.4, 0.8)",
      "spring": "cubic-bezier(0.34, 1.56, 0.64, 1)"
    }
  },
  "iconography": {
    "style": "illustrated",
    "pack": "open-doodles"
  },
  "borders": {
    "width": 0,
    "style": "solid",
    "treatment": "soft"
  },
  "elevation": {
    "shadows": [
      "none",
      "0 2px 4px rgba(255, 107, 157, 0.12)",
      "0 4px 12px rgba(255, 107, 157, 0.18), 0 2px 4px rgba(76, 201, 240, 0.08)",
      "0 8px 24px rgba(255, 107, 157, 0.22), 0 4px 8px rgba(76, 201, 240, 0.12)",
      "0 16px 48px rgba(255, 107, 157, 0.24), 0 8px 16px rgba(76, 201, 240, 0.14)"
    ],
    "surfaceTreatment": "paper"
  },
  "illustrationStylePrompt": "rounded chunky cartoon, soft pastel palette, friendly mascot, cheerful, simple shapes, plain background, no text, child-friendly, age 5-10",
  "logoPrimitiveConstraints": {
    "allowedShapeKinds": ["rounded-square", "circle", "blob", "star-rounded", "heart"],
    "allowedMarkKinds": ["mascot", "monogram-rounded", "icon-doodle"],
    "allowedWordmarkStyles": ["chunky-sans", "rounded-display", "handwritten"],
    "allowedContainerStyles": ["badge-soft", "stacked", "horizontal"]
  },
  "defaultDensity": "comfy",
  "voice": {
    "tone": ["warm", "encouraging", "playful", "simple"],
    "samples": {
      "primaryAction": "Let's go!",
      "errorEmpty": "Oops, nothing here yet — try adding one!",
      "successToast": "Yay! You did it!",
      "loading": "Hang on, almost there...",
      "welcome": "Hi friend! Ready to play?"
    }
  },
  "formIntelligence": {
    "validationStyle": "lenient",
    "suggestionMode": "aggressive",
    "groupingStrategy": "semantic",
    "progressiveDisclosure": "always",
    "smartDefaults": {
      "country": "browser",
      "language": "browser",
      "timezone": "browser"
    },
    "correctionTypes": ["typo"],
    "voice": {
      "validation": "playful and encouraging with emojis",
      "suggestion": "fun hints with celebrations",
      "success": "exciting with animations"
    }
  },
  "form": {
    "input": {
      "radius": "1rem"
    },
    "focus": {
      "ring": "0 0 0 4px rgba(240, 58, 133, 0.3)"
    },
    "state": {
      "error": {
        "color": "#E62929"
      },
      "success": {
        "color": "#06D6A0"
      },
      "warning": {
        "color": "#E0A41B"
      }
    },
    "suggestion": {
      "background": "#FFF0F6",
      "text": "#727A8B"
    },
    "group": {
      "spacing": "1.5rem",
      "border": "2px solid #FFD9E9"
    },
    "transition": {
      "duration": "320ms"
    }
  }
}
