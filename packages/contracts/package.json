{
  "name": "@skeed/contracts",
  "version": "0.1.0",
  "description": "Skeed shared interfaces and Zod schemas. The single source of truth for every type that crosses a package boundary.",
  "license": "MIT",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./demographic": "./src/demographic.ts",
    "./component": "./src/component.ts",
    "./preset": "./src/preset.ts",
    "./archetype": "./src/archetype.ts",
    "./psychology": "./src/psychology.ts",
    "./asset-source": "./src/asset-source.ts",
    "./llm-provider": "./src/llm-provider.ts",
    "./research-engine": "./src/research-engine.ts",
    "./score-rubric": "./src/score-rubric.ts",
    "./stage": "./src/stage.ts",
    "./guard": "./src/guard.ts",
    "./pipeline-types": "./src/pipeline-types.ts",
    "./layout-dsl": "./src/layout-dsl.ts",
    "./event-taste": "./src/event-taste.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
