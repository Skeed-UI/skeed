{
  "name": "@skeed/cli",
  "version": "0.1.0",
  "description": "Skeed CLI — `npx skeed init '<idea>'` scaffolds a demographic-tuned Next.js project.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "skeed": "./bin/skeed.mjs"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "files": ["bin", "dist", "templates"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "dev": "tsx src/index.ts"
  },
  "dependencies": {
    "@skeed/contracts": "workspace:*",
    "@skeed/pipeline": "workspace:*",
    "cac": "^6.7.14",
    "kleur": "^4.1.5",
    "open": "^10.1.0",
    "tsx": "^4.19.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
