{
  "name": "@skeed/llm-router",
  "version": "0.1.0",
  "description": "Multi-provider LLM router with multi-strategy JSON extraction, schema-validated retry loop, SQLite cache. DeepSeek-first with fallback chain.",
  "license": "MIT",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./extract": "./src/extract.ts",
    "./providers": "./src/providers/index.ts",
    "./registry": "./src/registry.ts",
    "./validator": "./src/code-validator.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@skeed/contracts": "workspace:*",
    "better-sqlite3": "^11.7.0",
    "jsonrepair": "^3.11.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
