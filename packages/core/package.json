{
  "name": "@skeed/core",
  "version": "0.1.0",
  "description": "Skeed core: design tokens API, deterministic preset→CSS transformer, class-merge helper. Pure functions, no I/O.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./tokens": {
      "types": "./dist/tokens.d.ts",
      "import": "./dist/tokens.js",
      "default": "./dist/tokens.js"
    },
    "./transformer": {
      "types": "./dist/transformer.d.ts",
      "import": "./dist/transformer.js",
      "default": "./dist/transformer.js"
    },
    "./token-resolver": {
      "types": "./dist/token-resolver.d.ts",
      "import": "./dist/token-resolver.js",
      "default": "./dist/token-resolver.js"
    },
    "./cn": {
      "types": "./dist/cn.d.ts",
      "import": "./dist/cn.js",
      "default": "./dist/cn.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@skeed/contracts": "workspace:*"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
