{
  "name": "@skeed/core",
  "version": "0.1.0",
  "description": "Skeed core: design tokens API, deterministic preset→CSS transformer, class-merge helper. Pure functions, no I/O.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./tokens": {
      "types": "./dist/tokens.d.ts",
      "import": "./dist/tokens.js",
      "default": "./dist/tokens.js"
    },
    "./transformer": {
      "types": "./dist/transformer.d.ts",
      "import": "./dist/transformer.js",
      "default": "./dist/transformer.js"
    },
    "./token-resolver": {
      "types": "./dist/token-resolver.d.ts",
      "import": "./dist/token-resolver.js",
      "default": "./dist/token-resolver.js"
    },
    "./cn": {
      "types": "./dist/cn.d.ts",
      "import": "./dist/cn.js",
      "default": "./dist/cn.js"
    },
    "./form-grouping": {
      "types": "./dist/form-grouping.d.ts",
      "import": "./dist/form-grouping.js",
      "default": "./dist/form-grouping.js"
    },
    "./form-context": {
      "types": "./dist/form-context.d.ts",
      "import": "./dist/form-context.js",
      "default": "./dist/form-context.js"
    },
    "./form-validation": {
      "types": "./dist/form-validation.d.ts",
      "import": "./dist/form-validation.js",
      "default": "./dist/form-validation.js"
    },
    "./form-suggestions": {
      "types": "./dist/form-suggestions.d.ts",
      "import": "./dist/form-suggestions.js",
      "default": "./dist/form-suggestions.js"
    },
    "./form-tokens": {
      "types": "./dist/form-tokens.d.ts",
      "import": "./dist/form-tokens.js",
      "default": "./dist/form-tokens.js"
    },
    "./smart-defaults": {
      "types": "./dist/smart-defaults.d.ts",
      "import": "./dist/smart-defaults.js",
      "default": "./dist/smart-defaults.js"
    },
    "./progressive-disclosure": {
      "types": "./dist/progressive-disclosure.d.ts",
      "import": "./dist/progressive-disclosure.js",
      "default": "./dist/progressive-disclosure.js"
    },
    "./use-form-validation": {
      "types": "./dist/use-form-validation.d.ts",
      "import": "./dist/use-form-validation.js",
      "default": "./dist/use-form-validation.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@skeed/contracts": "workspace:*"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
