{
  "name": "@skeed/pipeline",
  "version": "0.1.0",
  "description": "Skeed 17-stage NL→design-system pipeline. DAG runner + stage contracts. Each stage is owned by an agent.",
  "license": "MIT",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./orchestrator": "./src/orchestrator.ts",
    "./stages/*": "./src/stages/*"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@skeed/asset-logo-svg": "workspace:*",
    "@skeed/assets-router": "workspace:*",
    "@skeed/contracts": "workspace:*",
    "@skeed/demographics-loader": "workspace:*",
    "@skeed/guards": "workspace:*",
    "@skeed/landing-options": "workspace:*",
    "@skeed/llm-router": "workspace:*",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
