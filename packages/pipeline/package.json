{
  "name": "@skeed/pipeline",
  "version": "0.1.0",
  "description": "Skeed 17-stage NL→design-system pipeline. DAG runner + stage contracts. Each stage is owned by an agent.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./orchestrator": {
      "import": "./dist/orchestrator.js",
      "types": "./dist/orchestrator.d.ts"
    },
    "./stages/*": {
      "import": "./dist/stages/*.js",
      "types": "./dist/stages/*.d.ts"
    }
  },
  "files": ["dist"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@skeed/asset-logo-svg": "workspace:*",
    "@skeed/assets-router": "workspace:*",
    "@skeed/contracts": "workspace:*",
    "@skeed/demographics-loader": "workspace:*",
    "@skeed/guards": "workspace:*",
    "@skeed/landing-options": "workspace:*",
    "@skeed/llm-router": "workspace:*",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
